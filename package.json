  "description": "the healthcare appointment scheduling platform",
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node-dev --respawn src/server.ts",
    "worker": "ts-node-dev --respawn src/worker.ts",
    "dev:docker": "ts-node src/server.ts",
    "worker:docker": "ts-node src/worker.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run worker\""
